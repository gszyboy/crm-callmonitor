<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <!--
        ZXing Android Embedded handles the camera preview surface automatically.
        This layout only shows a minimal UI overlay with a prompt.
        The actual scanning view is provided by IntentIntegrator / CaptureActivity
        from the zxing-android-embedded library.
    -->

    <TextView
        android:id="@+id/tv_scan_prompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="48dp"
        android:text="@string/scan_prompt"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:background="#88000000"
        android:padding="12dp"
        android:elevation="4dp" />

</FrameLayout>
